# ============================================================
# ANOUANZÊ ERP — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# ============================================================

# Application
NODE_ENV=development
APP_NAME="ANOUANZÊ ERP"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Base de données PostgreSQL
DATABASE_URL="postgresql://anouanze:anouanze_password@localhost:5432/anouanze_erp?schema=public"
POSTGRES_USER=anouanze
POSTGRES_PASSWORD=anouanze_password
POSTGRES_DB=anouanze_erp

# Redis (cache, sessions, queues)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT & Sécurité
JWT_SECRET=change_this_secret_in_production_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production_at_least_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# Chiffrement
ENCRYPTION_KEY=change_this_32_char_encryption_key

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@anouanze-erp.com
SMTP_PASSWORD=
EMAIL_FROM="ANOUANZÊ ERP <noreply@anouanze-erp.com>"

# Stockage fichiers (S3 / MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=anouanze-erp
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/anouanze-erp

# Paiements mobiles
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=
MTN_MOMO_API_KEY=
MTN_MOMO_API_SECRET=
WAVE_API_KEY=

# --- CinetPay (agrégateur : Orange Money, MTN MoMo, Moov, Wave, cartes) ---
# Tant que CINETPAY_API_KEY / CINETPAY_SITE_ID / CINETPAY_NOTIFY_URL /
# CINETPAY_RETURN_URL ne sont pas tous renseignés, la passerelle reste
# INACTIVE et l'interface affiche « En intégration » (aucun appel sortant).
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
# Clé secrète du marchand — active la vérification HMAC du header x-token
# des notifications. Facultative : sans elle, chaque webhook est revalidé
# via /v2/payment/check (source de vérité).
CINETPAY_SECRET_KEY=
# PRODUCTION (défaut) ou TEST (journalisation verbeuse)
CINETPAY_MODE=PRODUCTION
# URL publique appelée par CinetPay (doit être joignable depuis Internet)
CINETPAY_NOTIFY_URL=https://votre-domaine.com/api/v1/paiements/webhook/cinetpay
# URL de retour du payeur après paiement
CINETPAY_RETURN_URL=https://votre-domaine.com/paiements
# Délai d'appel HTTP en ms (défaut 15000)
CINETPAY_TIMEOUT_MS=15000

# OAuth2 (Google, Microsoft)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# SMS
VONAGE_API_KEY=
VONAGE_API_SECRET=

# IA / OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Monitoring
SENTRY_DSN=

# Next.js (variables publiques)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=ws://localhost:4000
